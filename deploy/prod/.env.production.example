# =============================================================================
# SWAT2 Production — copy to SWAT-v2/.env on EC2
# cp deploy/prod/.env.production.example .env
# =============================================================================

NODE_ENV=production

# --- Public URLs (embedded in client bundle at build time) ---
NEXT_PUBLIC_APP_URL=https://swat.floyo.ai
NEXT_PUBLIC_MAIN_SITE_DOMAIN=https://floyo.ai
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Prod cookie domain — share session with floyo.ai
NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=.floyo.ai
SUPABASE_COOKIE_DOMAIN=.floyo.ai

# --- Server-only Supabase ---
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Dispatcher (SWAT isolated backend on this EC2) ---
NEXT_PUBLIC_GLOBAL_DISPATCHER_URL=https://swat.dispatch.floyo.ai
# Must match global-dispatcher BACKEND_TOKEN on this host
DISPATCHER_BACKEND_TOKEN=your_backend_token
DISPATCHER_TEAM_ID=your_team_uuid
# Floyo user in that team (run attribution via x-user-id)
DISPATCHER_USER_ID=your_user_uuid

# --- Prompt service (baseline preflight — same EC2) ---
FLOYO_PROMPT_SERVICE_URL=http://127.0.0.1:8788/generate-prompt
SWAT_BASELINE_MODE=prompt_changed
SWAT_PREFLIGHT_CONCURRENCY=8

# --- Runtime ---
PORT=3000
HOSTNAME=0.0.0.0
