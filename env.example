# ---------------------------------------------------------------------------
# SWAT2 environment variables
# Copy this file to `.env` and fill in real values before running locally.
# ---------------------------------------------------------------------------

# Supabase (REQUIRED) - same project as the main Floyo app
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional service role key (server-only, used for admin reads if needed)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Main Floyo site (used for login redirect when unauthenticated)
NEXT_PUBLIC_MAIN_SITE_DOMAIN=https://dev.floyo.ai
# When running both apps locally, the main site port to redirect to
NEXT_PUBLIC_MAIN_SITE_PORT=3001

# Supabase cookie domain. Use "localhost" for local dev so cookies are shared.
NEXT_PUBLIC_SUPABASE_COOKIE_DOMAIN=localhost
SUPABASE_COOKIE_DOMAIN=localhost

# Dispatcher that actually runs the workflows
NEXT_PUBLIC_GLOBAL_DISPATCHER_URL=https://your-dispatcher-url

# Swat_Prod split mode: prod dispatcher auth (dev login won't work on dispatch.floyo.ai)
# Get access_token from prod Floyo session (sb-gnsl... cookie) or browser network tab.
# DISPATCHER_AUTH_ACCESS_TOKEN=
# Your prod team UUID (from floyo.ai URL or workflow_runs.team_id)
# DISPATCHER_TEAM_ID=

# OPTIONAL: Runtime prompt generation service.
# If set, SWAT2 will POST workflow_json here to get a fresh Comfy API prompt
# instead of trusting the stored workflows.prompt column.
# Expected response: { "success": true, "prompt": { ... } }
FLOYO_PROMPT_SERVICE_URL=http://127.0.0.1:8788/generate-prompt

# Node env
NODE_ENV=development

# Production deploy: see deploy/prod/README.md and deploy/prod/.env.production.example
